  <types>
    <dataTypes />
    <pous>
      <pou name="ccsSafeCraneNumberSuperv" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="in_CraneNoSet1">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> First crane number </xhtml>
              </documentation>
            </variable>
            <variable name="in_CraneNoSet2">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Second crane number </xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="out_S_CraneNoSupervOk">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml">Crane numbers match and are not an empty word</xhtml>
              </documentation>
            </variable>
            <variable name="out_S_CraneNo">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> A safe crane number. If crane numbers missmatch, this word is set to an empty word </xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="EmptyWord">
              <type>
                <WORD />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">out_S_CraneNoSupervOk :=
	(in_CraneNoSet1 = in_CraneNoSet2)
	AND (in_CraneNoSet1 &lt;&gt; EmptyWord);

IF out_S_CraneNoSupervOk THEN
	out_S_CraneNo := in_CraneNoSet1;
ELSE
	out_S_CraneNo := EmptyWord;
END_IF</xhtml>
          </ST>
        </body>
